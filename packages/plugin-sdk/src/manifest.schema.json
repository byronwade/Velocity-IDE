{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://velocity.dev/schemas/plugin-manifest.json",
  "title": "VelocityPluginManifest",
  "type": "object",
  "required": ["id", "name", "publisher", "version", "engine", "runtime", "activation", "permissions"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "publisher": { "type": "string" },
    "version": { "type": "string" },
    "engine": { "type": "string" },
    "runtime": { "enum": ["native", "legacy_vsix"] },
    "activation": { "type": "string" },
    "contributes": { "type": "object" },
    "permissions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "signature": { "type": "string" },
    "repository": { "type": "string" },
    "license": { "type": "string" },
    "performanceBudget": {
      "type": "object",
      "properties": {
        "activationMs": { "type": "number" },
        "idleMemoryMb": { "type": "number" }
      }
    }
  }
}
