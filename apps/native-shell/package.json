{
  "name": "@velocity/native-shell",
  "private": true,
  "version": "0.1.0",
  "description": "Velocity IDE native shell (Native SDK). Codename is rename-ready.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/byronwade/Velocity-IDE.git",
    "directory": "apps/native-shell"
  },
  "bugs": {
    "url": "https://github.com/byronwade/Velocity-IDE/issues"
  },
  "homepage": "https://github.com/byronwade/Velocity-IDE#readme",
  "scripts": {
    "dev": "native dev --yes",
    "check": "native test --yes && native check --strict",
    "build": "native build --yes",
    "test": "native test --yes",
    "clean": "rm -rf .native zig-out zig-cache .zig-cache",
    "smoke": "npm run perf-smoke && npm run task-smoke && npm run test-smoke && npm run launch-smoke && npm run explorer-smoke && npm run review-snippet-smoke && npm run terminal-smoke && npm run diagnostics-smoke",
    "perf-smoke": "bash scripts/perf-smoke.sh",
    "task-smoke": "bash scripts/task-smoke.sh",
    "test-smoke": "bash scripts/test-smoke.sh",
    "launch-smoke": "bash scripts/launch-smoke.sh",
    "explorer-smoke": "bash scripts/explorer-smoke.sh",
    "review-snippet-smoke": "bash scripts/review-snippet-smoke.sh",
    "terminal-smoke": "bash scripts/terminal-smoke.sh",
    "diagnostics-smoke": "bash scripts/diagnostics-smoke.sh",
    "lsp-smoke": "bash scripts/lsp-smoke.sh",
    "build-lsp-broker": "bash scripts/build-lsp-broker.sh",
    "doctor": "native doctor"
  },
  "engines": {
    "node": ">=22"
  }
}
